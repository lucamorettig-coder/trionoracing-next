# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/portale/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/portale/registrati
# EVO-027: redirect "fallback" moderni — rispettano il redirect_url ma cadono su /portale.
# (i deprecati AFTER_SIGN_IN/UP_URL, se vuoti in prod, mandano alla landing dopo il login)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portale
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/portale

# Airtable
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# Base Marathon 209 (duezeronove-2026). Stesso PAT, scope multi-base.
AIRTABLE_BASE_ID_209=appXXXXXXXXXXXXXX
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX
# Nome tabella gare (parametrizzato per cambio anno solare). Default: "Gare Giovanili Umbria 2026".
AIRTABLE_TABLE_GARE=Gare Giovanili Umbria 2026
# Nome tabella impostazioni/contatti sito (key→value, gestita dall'admin). Default: "Impostazioni Sito".
AIRTABLE_TABLE_IMPOSTAZIONI=Impostazioni Sito

# SumUp
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
# URL del webhook Make.com (scenario "ricevute pagamento + aggiornamento iscrizione").
# Passato a SumUp come return_url ad ogni checkout → SumUp notifica Make → Make scrive PAGATO=true su Airtable.
# Senza questo, il fallback "browser chiuso prima del verify" non funziona.
MAKE_SUMUP_RETURN_URL=

# Google Analytics 4 (Measurement ID). Se assente, GA non viene caricato.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Migrazione Supabase → Clerk (EVO-008, script CLI one-shot in scripts/migrate-clerk/)
# Connection string del Postgres legacy per leggere auth.users (con encrypted_password).
# Supabase Dashboard → Project Settings → Database → Connection string → URI.
# Serve solo per export-supabase-users.ts; non usato dall'app runtime.
SUPABASE_DB_URL=postgresql://postgres:<PWD>@db.<ref>.supabase.co:5432/postgres
